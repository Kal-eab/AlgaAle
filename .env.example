# Copy to .env to override defaults
PORT=3000
SESSION_SECRET=change-this-to-a-long-random-string
ADMIN_EMAIL=admin@alga.et
ADMIN_PASSWORD=Wubalem@12


# Cloudinary — REQUIRED for photo uploads to work.
# Without these, adding photos to a listing fails with a server error.
# Find them in your Cloudinary dashboard (Settings -> API Keys).
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
