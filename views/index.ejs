<%- include('partials/header', { title: 'AlgaAle — Affordable beds & rooms in Addis Ababa' }) %>

<section class="hero home-hero">
  <div class="container">
    <h1>Find affordable beds, rooms, and rentals across Addis Ababa in minutes.</h1>
    <p class="hero-sub">Single beds · shared rooms · student hostels · spare rooms · studios — no brokers, no scams, no stress.</p>

    <%- include('partials/searchbar', { filters: {}, compact: false }) %>

    <div class="area-chips-row">
      <div class="area-chips">
        <% C.AREAS.forEach(function(a){ %>
          <a class="chip" href="/search?area=<%= encodeURIComponent(a) %>">📍 <%= a %></a>
        <% }) %>
      </div>
    </div>
  </div>
</section>

<section class="container popular">
  <h2 class="section-title">Popular in Addis Ababa</h2>

  <% if (popular.length) { %>
    <div class="popular-tabs" data-popular-tabs>
      <% popular.forEach(function(g, i){ %>
        <button type="button" class="popular-tab <%= i === 0 ? 'is-active' : '' %>" data-tab="<%= g.area %>"><%= g.area %></button>
      <% }) %>
    </div>

    <% popular.forEach(function(g, i){ %>
      <div class="popular-panel <%= i === 0 ? 'is-active' : '' %>" data-panel="<%= g.area %>">
        <div class="popular-grid">
          <% g.listings.forEach(function(l){ %>
            <a class="pcard" href="/listing/<%= l.id %>">
              <div class="pcard-media">
                <img src="<%= firstPhoto(l) || ('/placeholder.svg?text=' + encodeURIComponent(C.typeLabel(l.type))) %>" alt="<%= l.title %>" loading="lazy" />
                <% if (l.featured) { %><span class="ribbon ribbon-featured">★ Featured</span><% } %>
              </div>
              <div class="pcard-body">
                <h3 class="pcard-title"><%= l.title %></h3>
                <div class="pcard-meta">📍 <%= l.area %> · <%= C.typeLabel(l.type) %></div>
                <div class="pcard-price"><%= money(l.price) %> birr <span class="muted">/ <%= C.periodLabel(l.period).toLowerCase() %></span></div>
              </div>
            </a>
          <% }) %>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <p class="muted">No listings yet — check back soon.</p>
  <% } %>
</section>

<script src="/js/search.js" defer></script>

<%- include('partials/footer') %>
