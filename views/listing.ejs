<%- include('partials/header', { title: listing.title + ' — Alga' }) %>

<div class="container listing-page">
  <a href="/" class="back-link">← Back to results</a>

  <div class="listing-top">
    <div>
      <div class="listing-badges">
        <% if (listing.featured) { %><span class="badge badge-featured">★ Featured</span><% } %>
        <% if (listing.verified) { %><span class="badge badge-verified">✅ Verified by Alga</span><% } %>
        <span class="badge badge-type"><%= C.typeLabel(listing.type) %></span>
      </div>
      <h1><%= listing.title %></h1>
      <div class="listing-meta">📍 <%= listing.area %>, Addis Ababa
        <% if (avg) { %> · ★ <%= avg %> (<%= reviews.length %> review<%= reviews.length === 1 ? '' : 's' %>)<% } %>
      </div>
    </div>
    <div class="listing-price-box">
      <div class="big-price"><%= money(listing.price) %> birr</div>
      <div class="muted">per <%= C.periodLabel(listing.period).toLowerCase().replace('ly','') %></div>
    </div>
  </div>

  <!-- Photo gallery by category -->
  <section class="gallery">
    <% C.PHOTO_CATEGORIES.forEach(function(cat){
         var imgs = (listing.photos && listing.photos[cat]) || [];
         var label = cat.charAt(0).toUpperCase() + cat.slice(1);
    %>
      <div class="gallery-group">
        <h4><%= label %></h4>
        <div class="gallery-row">
          <% if (imgs.length) { imgs.forEach(function(src){ %>
            <a href="<%= src %>" target="_blank" class="gallery-thumb"><img src="<%= src %>" alt="<%= label %>" loading="lazy" /></a>
          <% }) } else { %>
            <div class="gallery-thumb placeholder"><img src="/placeholder.svg?text=<%= encodeURIComponent(label) %>" alt="<%= label %> photo coming soon" /></div>
          <% } %>
        </div>
      </div>
    <% }) %>
  </section>

  <div class="listing-grid">
    <div class="listing-main">
      <section class="panel">
        <h3>About this place</h3>
        <p class="desc"><%= listing.description || 'No description provided yet.' %></p>

        <h4>Details</h4>
        <ul class="detail-list">
          <li><strong>Type:</strong> <%= C.typeLabel(listing.type) %></li>
          <li><strong>Term:</strong> <%= C.periodLabel(listing.period) %></li>
          <li><strong>Suitable for:</strong> <%= C.audienceLabel(listing.audience) %></li>
          <li><strong>Area:</strong> <%= listing.area %></li>
        </ul>

        <h4>Amenities</h4>
        <div class="amenity-list">
          <span class="amenity <%= listing.furnished ? 'on' : 'off' %>"><%= listing.furnished ? '✔' : '—' %> Furnished</span>
          <span class="amenity <%= listing.wifi ? 'on' : 'off' %>"><%= listing.wifi ? '✔' : '—' %> WiFi</span>
          <span class="amenity <%= listing.water ? 'on' : 'off' %>"><%= listing.water ? '✔' : '—' %> Water available</span>
          <span class="amenity <%= listing.parking ? 'on' : 'off' %>"><%= listing.parking ? '✔' : '—' %> Parking</span>
        </div>
      </section>

      <!-- Reviews -->
      <section class="panel">
        <h3>Reviews <% if (avg) { %><span class="muted">★ <%= avg %></span><% } %></h3>
        <% if (reviews.length === 0) { %>
          <p class="muted">No reviews yet. Be the first to share your experience.</p>
        <% } %>
        <% reviews.forEach(function(r){ %>
          <div class="review">
            <div class="review-head"><strong><%= r.name %></strong> <span class="stars">★ <%= r.rating %>/5</span></div>
            <p><%= r.comment %></p>
          </div>
        <% }) %>

        <form action="/listing/<%= listing.id %>/review" method="POST" class="review-form">
          <h4>Leave a review</h4>
          <div class="row">
            <input type="text" name="name" placeholder="Your name" required />
            <select name="rating">
              <% for (var i=5;i>=1;i--){ %><option value="<%= i %>">★ <%= i %></option><% } %>
            </select>
          </div>
          <textarea name="comment" placeholder="How was your stay?" rows="3" required></textarea>
          <button type="submit" class="btn btn-ghost">Post review</button>
        </form>
      </section>
    </div>

    <!-- Booking sidebar -->
    <aside class="listing-side">
      <div class="panel booking-box">
        <h3>Request to book</h3>
        <p class="muted">Chat through Alga first — no phone numbers shared until the host accepts. Safer for everyone.</p>
        <form action="/listing/<%= listing.id %>/book" method="POST">
          <input type="text" name="name" placeholder="Your full name" required />
          <input type="tel" name="phone" placeholder="Your phone number" required />
          <input type="text" name="duration" placeholder="How long? e.g. 2 weeks, 3 months" />
          <textarea name="message" rows="3" placeholder="Tell the host a little about yourself…"></textarea>
          <button type="submit" class="btn btn-primary btn-block">Send booking request</button>
        </form>
      </div>

      <div class="panel host-box">
        <h4>Hosted by</h4>
        <p><strong><%= listing.ownerName || 'Alga host' %></strong></p>
        <p class="muted">Contact details are shared after your request is accepted.</p>
      </div>
    </aside>
  </div>
</div>

<%- include('partials/footer') %>
