<%- include('partials/header', { title: 'Choose your room — ' + listing.title }) %>
<div class="container">
  <a href="/listing/<%= listing.id %>" class="back-link">← Back</a>
  <h1 style="margin:12px 0;">Choose your room</h1>
  <p class="muted"><%= checkin %> – <%= checkout %> · <%= nights %> night<%= nights > 1 ? 's' : '' %> · <%= guests %> guest<%= guests > 1 ? 's' : '' %></p>
  <% rooms.forEach(function(rm){ var price = Math.round(rm.nightlyRate * nights); %>
    <div class="panel" style="display:flex;gap:14px;align-items:center;margin-bottom:14px;">
      <% if (rm.photo) { %>
        <img src="<%= rm.photo %>" alt="" style="width:110px;height:84px;object-fit:cover;border-radius:8px;" />
      <% } else { %>
        <div style="width:110px;height:84px;border-radius:8px;background:#e5e7eb;"></div>
      <% } %>
      <div style="flex:1;">
        <strong><%= rm.name %></strong>
        <div class="muted" style="font-size:.85rem;">Sleeps <%= rm.capacity %></div>
        <div style="margin-top:6px;"><strong><%= money(price) %> birr</strong> <span class="muted">for <%= nights %> night<%= nights > 1 ? 's' : '' %></span></div>
      </div>
      <a class="btn btn-primary"
         href="/listing/<%= listing.id %>/reserve?checkin=<%= encodeURIComponent(checkin) %>&checkout=<%= encodeURIComponent(checkout) %>&guests=<%= guests %>&room=<%= rm.id %>">Select</a>
    </div>
  <% }) %>
</div>
<%- include('partials/footer') %>
