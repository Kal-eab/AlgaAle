</main>
<footer class="site-footer">
  <div class="container footer-inner">
    <div>
      <div class="brand brand-footer">AlgaAle</div>
      <p class="muted">Find affordable beds, rooms, and rentals across Addis Ababa in minutes.</p>
    </div>
    <div class="footer-cols">
      <div>
        <h4>Popular areas</h4>
        <ul>
          <% C.AREAS.slice(0,5).forEach(function(a){ %>
            <li><a href="/?area=<%= encodeURIComponent(a) %>"><%= a %></a></li>
          <% }) %>
        </ul>
      </div>
      <div>
        <h4>For hosts</h4>
        <ul>
          <li><a href="/admin/login">List your bed</a></li>
          <li><a href="/admin/login">Get verified</a></li>
        </ul>
      </div>
    </div>
  </div>
  <div class="container footer-bottom muted">© <%= new Date().getFullYear() %> AlgaAle · Addis Ababa, Ethiopia</div>
</footer>
<script>
  // Profile dropdown toggle
  const menu = document.querySelector('.profile-menu');
  if (menu) {
    menu.querySelector('.profile-trigger').addEventListener('click', function(e) {
      e.stopPropagation();
      menu.classList.toggle('open');
    });
    document.addEventListener('click', function() {
      menu.classList.remove('open');
    });
  }
</script>
</body>
</html>
