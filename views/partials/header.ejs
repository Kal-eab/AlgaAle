<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'AlgaAle — Affordable beds & rooms in Addis Ababa' %></title>
  <meta name="description" content="Find affordable beds, rooms, and rentals across Addis Ababa in minutes." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="stylesheet" href="/css/styles.css" />
  <link rel="icon" href="/logo.png" type="image/png" />
</head>
<body>
<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand">
      <img src="/logo.png" alt="AlgaAle" class="brand-logo" />
    </a>
    <nav class="main-nav">
      <a href="/">Browse</a>

      <% if (!user) { %>
        <a href="/register" class="btn btn-ghost btn-sm">Register</a>
        <a href="/login" class="btn btn-primary btn-sm">Log in</a>

      <% } else if (user.role === 'seeker') { %>
        <span style="color:var(--body);font-size:.9rem;">Hi, <%= user.fullName.split(' ')[0] %></span>
        <% if (user.providerAppStatus === 'pending') { %>
          <span class="btn btn-ghost btn-sm" style="opacity:.6;cursor:default;">Application pending</span>
        <% } else { %>
          <a href="/become-provider" class="btn btn-ghost btn-sm">List your home</a>
        <% } %>
        <form action="/logout" method="POST" class="inline-form">
          <button type="submit" class="btn btn-ghost btn-sm">Log out</button>
        </form>

      <% } else if (user.role === 'provider') { %>
        <span style="color:var(--body);font-size:.9rem;">Hi, <%= user.fullName.split(' ')[0] %></span>
        <a href="/provider" class="btn btn-ghost btn-sm">My listings</a>
        <form action="/logout" method="POST" class="inline-form">
          <button type="submit" class="btn btn-ghost btn-sm">Log out</button>
        </form>

      <% } else if (user.role === 'owner') { %>
        <a href="/admin" class="btn btn-primary btn-sm">Owner panel</a>
        <form action="/logout" method="POST" class="inline-form">
          <button type="submit" class="btn btn-ghost btn-sm">Log out</button>
        </form>

      <% } else if (user.role === 'admin') { %>
        <a href="/admin" class="btn btn-ghost btn-sm">Dashboard</a>
        <form action="/admin/logout" method="POST" class="inline-form">
          <button type="submit" class="btn btn-ghost btn-sm">Log out</button>
        </form>
      <% } %>
    </nav>
  </div>
</header>

<% if (flash.success && flash.success.length) { %>
  <div class="container"><div class="alert alert-success"><%= flash.success[0] %></div></div>
<% } %>
<% if (flash.error && flash.error.length) { %>
  <div class="container"><div class="alert alert-error"><%= flash.error[0] %></div></div>
<% } %>

<main>
