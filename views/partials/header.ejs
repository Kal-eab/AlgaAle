<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'AlgaAle — Affordable beds & rooms in Addis Ababa' %></title>
  <meta name="description" content="Find affordable beds, rooms, and rentals across Addis Ababa in minutes." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="stylesheet" href="/css/styles.css" />
  <link rel="icon" href="/logo.png" type="image/png" />
</head>
<body>
<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand">
      <img src="/logo.png" alt="AlgaAle" class="brand-logo" />
    </a>
    <nav class="main-nav">
      <a href="/">Browse</a>

      <% if (!user) { %>
        <a href="/register" class="btn btn-ghost btn-sm">Register</a>
        <a href="/login" class="btn btn-primary btn-sm">Log in</a>

      <% } else { %>
        <div class="profile-menu">
          <button class="profile-trigger" aria-haspopup="true">
            <span class="profile-avatar"><%= user.fullName.charAt(0).toUpperCase() %></span>
            <span class="profile-name"><%= user.fullName.split(' ')[0] %></span>
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" style="opacity:.5"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>

          <div class="profile-dropdown">
            <div class="profile-dropdown-info">
              <div class="profile-dropdown-name"><%= user.fullName %></div>
              <div class="profile-dropdown-meta"><%= user.phone || user.email || '' %></div>
              <div class="profile-dropdown-role">
                <% if (user.role === 'owner') { %>
                  <span class="pill pill-featured" style="font-size:.7rem;">Owner</span>
                <% } else if (user.role === 'provider') { %>
                  <span class="pill pill-verified" style="font-size:.7rem;">Provider</span>
                <% } else if (user.role === 'seeker') { %>
                  <span class="pill pill-active" style="font-size:.7rem;">Seeker</span>
                <% } %>
              </div>
            </div>

            <div class="profile-dropdown-divider"></div>

            <% if (user.role === 'seeker') { %>
              <% if (user.providerAppStatus === 'pending') { %>
                <div class="profile-dropdown-item disabled">Application pending…</div>
              <% } else { %>
                <a href="/become-provider" class="profile-dropdown-item">List your home</a>
              <% } %>
            <% } else if (user.role === 'provider') { %>
              <a href="/provider" class="profile-dropdown-item">My listings</a>
            <% } else if (user.role === 'owner') { %>
              <div class="owner-nav-menu">
                <button class="profile-dropdown-item owner-nav-trigger" style="width:100%;text-align:left;background:none;border:none;cursor:pointer;display:flex;justify-content:space-between;align-items:center;">
                  Owner panel
                  <svg width="10" height="10" viewBox="0 0 12 12" fill="none" style="opacity:.4"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
                <div class="owner-nav-submenu">
                  <a href="/admin"               class="profile-dropdown-item" style="padding-left:1.5rem;">Dashboard</a>
                  <a href="/owner/members"        class="profile-dropdown-item" style="padding-left:1.5rem;">Members</a>
                  <a href="/owner/applications"   class="profile-dropdown-item" style="padding-left:1.5rem;">Applications</a>
                  <a href="/owner/listings"       class="profile-dropdown-item" style="padding-left:1.5rem;">All listings</a>
                  <a href="/admin/bookings"        class="profile-dropdown-item" style="padding-left:1.5rem;">Bookings</a>
                </div>
              </div>
            <% } else if (user.role === 'admin') { %>
              <a href="/admin" class="profile-dropdown-item">Admin panel</a>
            <% } %>

            <div class="profile-dropdown-divider"></div>

            <form action="<%= user.role === 'admin' ? '/admin/logout' : '/logout' %>" method="POST">
              <button type="submit" class="profile-dropdown-item profile-dropdown-logout">Log out</button>
            </form>
          </div>
        </div>
      <% } %>
    </nav>
  </div>
</header>

<% if (flash.success && flash.success.length) { %>
  <div class="container"><div class="alert alert-success"><%= flash.success[0] %></div></div>
<% } %>
<% if (flash.error && flash.error.length) { %>
  <div class="container"><div class="alert alert-error"><%= flash.error[0] %></div></div>
<% } %>

<main>
