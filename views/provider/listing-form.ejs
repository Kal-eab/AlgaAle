<% var editing = !!listing; %>
<%- include('../partials/header', { title: (editing ? 'Edit listing' : 'New listing') + ' — AlgaAle' }) %>

<div class="container admin">
  <div class="admin-head">
    <h1><%= editing ? 'Edit listing' : 'Add a listing' %></h1>
    <a href="/provider" class="btn btn-ghost">← My listings</a>
  </div>

  <% if (editing) { %>
    <p class="muted" style="margin:-6px 0 16px;">
      Guided setup:
      <a href="/provider/listings/<%= listing.id %>/setup/rooms">Edit rooms → step 2</a> ·
      <a href="/provider/listings/<%= listing.id %>/setup/photos">Edit photos → step 3</a>
    </p>
  <% } %>

  <form action="<%= editing ? '/provider/listings/' + listing.id : '/provider/listings' %>" method="POST" enctype="multipart/form-data" class="listing-form">
    <div class="form-grid">
      <div class="field span-2">
        <label>Title *</label>
        <input type="text" name="title" required value="<%= editing ? listing.title : '' %>" placeholder="e.g. Clean single bed in shared room — Bole" />
      </div>

      <div class="field">
        <label>Type *</label>
        <select name="type" required>
          <% C.TYPES.forEach(function(t){ %>
            <option value="<%= t.value %>" <%= editing && listing.type === t.value ? 'selected' : '' %>><%= t.label %></option>
          <% }) %>
        </select>
      </div>

      <div class="field">
        <label>Area *</label>
        <select name="area" required>
          <% C.AREAS.forEach(function(a){ %>
            <option value="<%= a %>" <%= editing && listing.area === a ? 'selected' : '' %>><%= a %></option>
          <% }) %>
        </select>
      </div>

      <div class="field">
        <label>Price (birr) *</label>
        <input type="number" name="price" min="0" step="50" required value="<%= editing ? listing.price : '' %>" />
      </div>

      <div class="field">
        <label>Rental term *</label>
        <select name="period" required>
          <% C.PERIODS.forEach(function(p){ %>
            <option value="<%= p.value %>" <%= editing && listing.period === p.value ? 'selected' : '' %>><%= p.label %></option>
          <% }) %>
        </select>
      </div>

      <div class="field">
        <label>Suitable for</label>
        <select name="audience">
          <% C.AUDIENCES.forEach(function(a){ %>
            <option value="<%= a.value %>" <%= editing && listing.audience === a.value ? 'selected' : '' %>><%= a.label %></option>
          <% }) %>
        </select>
      </div>

      <div class="field">
        <label>Visibility</label>
        <select name="status">
          <option value="active" <%= editing && listing.status === 'active' ? 'selected' : '' %>>Active (public)</option>
          <option value="hidden" <%= editing && listing.status === 'hidden' ? 'selected' : '' %>>Hidden</option>
        </select>
      </div>

      <div class="field span-2">
        <label>Description</label>
        <textarea name="description" rows="4" placeholder="Describe the room, compound, neighbourhood, and house rules…"><%= editing ? listing.description : '' %></textarea>
      </div>

      <div class="field">
        <label>Check-in from</label>
        <input type="time" name="checkinTime" value="<%= (editing && listing.checkinTime) || '14:00' %>" />
      </div>
      <div class="field">
        <label>Check-out before</label>
        <input type="time" name="checkoutTime" value="<%= (editing && listing.checkoutTime) || '11:00' %>" />
      </div>
      <div class="field span-2">
        <label>Cancellation policy</label>
        <textarea name="cancellationPolicy" rows="2" placeholder="e.g. Non-refundable once paid; free date change up to 48h before check-in."><%= (editing && listing.cancellationPolicy) || '' %></textarea>
      </div>
    </div>

    <fieldset class="amenity-fieldset">
      <legend>Amenities</legend>
      <% C.AMENITIES.forEach(function(am){ %>
        <label class="check"><input type="checkbox" name="<%= am.key %>" <%= editing && listing[am.key] ? 'checked' : '' %>> <%= am.label %></label>
      <% }) %>
    </fieldset>

    <fieldset class="photo-fieldset">
      <legend>Photos</legend>
      <p class="muted">Listings with real photos get significantly more inquiries.</p>
      <div class="photo-grid">
        <% C.PHOTO_CATEGORIES.forEach(function(cat){
             var label = cat.charAt(0).toUpperCase() + cat.slice(1);
             var imgs = editing && listing.photos && listing.photos[cat] ? listing.photos[cat] : [];
        %>
          <div class="photo-cat">
            <label><%= label %></label>
            <input type="file" name="photo_<%= cat %>" accept="image/jpeg,image/png,image/webp" multiple />
            <% if (imgs.length) { %>
              <div class="existing-photos">
                <% imgs.forEach(function(src){ %>
                  <div class="existing-photo">
                    <img src="<%= src %>" alt="" />
                    <% if (editing) { %>
                    <button type="submit"
                            form="delphoto-<%= cat %>-<%= src.replace(/[^a-zA-Z0-9]/g,'') %>"
                            class="photo-del" title="Remove">×</button>
                    <% } %>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </div>
        <% }) %>
      </div>
    </fieldset>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary"><%= editing ? 'Save changes' : 'Create listing' %></button>
      <a href="/provider" class="btn btn-ghost">Cancel</a>
    </div>
  </form>

  <%# Delete-photo forms live OUTSIDE the main form to avoid invalid nesting %>
  <% if (editing) { %>
    <% C.PHOTO_CATEGORIES.forEach(function(cat){
         var imgs = (listing.photos && listing.photos[cat]) ? listing.photos[cat] : [];
         imgs.forEach(function(src){ %>
      <form id="delphoto-<%= cat %>-<%= src.replace(/[^a-zA-Z0-9]/g,'') %>"
            action="/provider/listings/<%= listing.id %>/photo/delete" method="POST"
            style="display:none;">
        <input type="hidden" name="category" value="<%= cat %>" />
        <input type="hidden" name="url" value="<%= src %>" />
      </form>
    <% }); }) %>
  <% } %>

  <% if (editing) { %>
  <section class="panel" style="margin-top:24px;">
    <h3>Rooms &amp; bed options</h3>
    <p class="muted">
      Add the bookable rooms or beds in this place (e.g. "Queen pod", "Bunk bed").
      Guests booking a Daily or Weekly stay choose from these. If this is a single
      room/bed, leave it empty — it'll be booked as one unit at the listing price.
    </p>

    <% if (rooms && rooms.length) { %>
      <% rooms.forEach(function(rm){ %>
        <div class="panel" style="display:flex;gap:14px;align-items:flex-start;margin-bottom:14px;">
          <div style="flex:0 0 90px;">
            <% if (rm.photo) { %>
              <img src="<%= rm.photo %>" alt="" style="width:90px;height:70px;object-fit:cover;border-radius:8px;" />
            <% } else { %>
              <div style="width:90px;height:70px;border-radius:8px;background:#e5e7eb;display:flex;align-items:center;justify-content:center;font-size:.7rem;color:#9ca3af;">No photo</div>
            <% } %>
          </div>
          <form action="/provider/listings/<%= listing.id %>/rooms/<%= rm.id %>" method="POST"
                enctype="multipart/form-data" style="flex:1;display:grid;grid-template-columns:1fr 1fr;gap:10px;">
            <div class="field" style="grid-column:1 / -1;">
              <label>Room name</label>
              <input type="text" name="name" value="<%= rm.name %>" required />
            </div>
            <div class="field">
              <label>Capacity (guests)</label>
              <input type="number" name="capacity" min="1" value="<%= rm.capacity %>" />
            </div>
            <div class="field">
              <label>Nightly rate (birr)</label>
              <input type="number" name="nightlyRate" min="0" step="50" value="<%= rm.nightlyRate %>" />
            </div>
            <div class="field">
              <label>Units of this room</label>
              <input type="number" name="totalUnits" min="1" value="<%= rm.totalUnits || 1 %>" />
            </div>
            <div class="field">
              <label>Bed type</label>
              <select name="bedType">
                <option value="">—</option>
                <% ['single','double','twin','queen','king'].forEach(function(bt){ %>
                  <option value="<%= bt %>" <%= rm.bedType === bt ? 'selected' : '' %>><%= bt.charAt(0).toUpperCase() + bt.slice(1) %></option>
                <% }) %>
              </select>
            </div>
            <%- include('_room-numbers-field', { value: (rm.roomNumbers || []).join(', ') }) %>
            <div class="field" style="grid-column:1 / -1;">
              <label>Replace photo (optional)</label>
              <input type="file" name="photo" accept="image/jpeg,image/png,image/webp" />
            </div>
            <div style="grid-column:1 / -1;">
              <button type="submit" class="btn btn-sm btn-primary">Save room</button>
            </div>
          </form>
          <form action="/provider/listings/<%= listing.id %>/rooms/<%= rm.id %>/delete" method="POST"
                onsubmit="return confirm('Remove this room?')">
            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
          </form>
        </div>
      <% }) %>
    <% } else { %>
      <p class="muted">No rooms added yet — this listing will be booked as a single unit.</p>
    <% } %>

    <h4 style="margin-top:18px;">Add a room</h4>
    <form action="/provider/listings/<%= listing.id %>/rooms" method="POST"
          enctype="multipart/form-data" style="display:grid;grid-template-columns:1fr 1fr;gap:10px;max-width:560px;">
      <div class="field" style="grid-column:1 / -1;">
        <label>Room name *</label>
        <input type="text" name="name" placeholder="e.g. Queen pod" required />
      </div>
      <div class="field">
        <label>Capacity (guests)</label>
        <input type="number" name="capacity" min="1" value="1" />
      </div>
      <div class="field">
        <label>Nightly rate (birr) *</label>
        <input type="number" name="nightlyRate" min="0" step="50" required />
      </div>
      <div class="field">
        <label>Units of this room</label>
        <input type="number" name="totalUnits" min="1" value="1" />
        <span class="muted" style="font-size:.75rem;">How many identical rooms you have (drives availability)</span>
      </div>
      <div class="field">
        <label>Bed type</label>
        <select name="bedType">
          <option value="">—</option>
          <% ['single','double','twin','queen','king'].forEach(function(bt){ %>
            <option value="<%= bt %>"><%= bt.charAt(0).toUpperCase() + bt.slice(1) %></option>
          <% }) %>
        </select>
      </div>
      <%- include('_room-numbers-field', { value: '' }) %>
      <div class="field" style="grid-column:1 / -1;">
        <label>Photo (optional)</label>
        <input type="file" name="photo" accept="image/jpeg,image/png,image/webp" />
      </div>
      <div style="grid-column:1 / -1;">
        <button type="submit" class="btn btn-primary">Add room</button>
      </div>
    </form>
  </section>
  <% } %>
</div>

<% if (editing) { %><%- include('_room-numbers-script') %><% } %>
<%- include('../partials/footer') %>
